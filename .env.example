# EGX Live Connector Ready System

# Modes:
# file_csv           = read data/live-prices.csv locally
# http_json          = read a licensed JSON API endpoint
# mubasher_official  = read official Mubasher/partner API endpoint if you have one
# egx_public_manual  = safe placeholder; use CSV/import unless you have official API
SOURCE_MODE=file_csv

PORT=3000
POLL_SECONDS=10

# For http_json:
EGX_API_URL=
EGX_API_KEY=
EGX_API_KEY_HEADER=Authorization
EGX_API_KEY_PREFIX=Bearer

# For mubasher_official:
MUBASHER_API_URL=
MUBASHER_API_TOKEN=
MUBASHER_TOKEN_HEADER=Authorization
MUBASHER_TOKEN_PREFIX=Bearer
